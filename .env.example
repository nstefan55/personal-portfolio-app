# Copy to .env.local and fill in. .env.local is gitignored — never commit real keys.

# Resend — required for /api/contact email delivery. Get a key at https://resend.com
RESEND_API_KEY=

# Where contact submissions are delivered (optional; defaults to nikola.stefancic@gmail.com)
CONTACT_TO=nikola.stefancic@gmail.com

# Sender identity (optional). Free tier without a verified domain: keep onboarding@resend.dev
# (Resend then only delivers to your own Resend account email). Verify a domain to send freely.
RESEND_FROM=Portfolio <onboarding@resend.dev>
